-- ############################################################################
-- ODATA EXAMPLES
-- ############################################################################
--
-- This file demonstrates the MDL syntax for OData clients (consumed services),
-- OData services (published services), and external entities.
--
-- Prerequisites: Assumes a module 'OdTest' exists with some entities.
--
-- ############################################################################

create module OdTest;

-- Create some entities that will be published via OData.
--
-- Best-practice: never publish the system `Id` as the OData key — it leaks
-- internal storage IDs. Use a business attribute with a UNIQUE constraint
-- so it can serve as a stable public key.
-- The business key attribute (Email / OrderNumber) gets both UNIQUE and
-- REQUIRED validation rules. Mendix's OData publish demands that the
-- attribute exposed as KEY always has a value — a missing key value
-- would yield a row Mendix can't address via /Service/Entity('key').
create persistent entity OdTest.Customer (
  Name: string(200),
  Email: string(200) unique error 'Email must be unique' required error 'Email is required',
  Phone: string(50),
  IsActive: boolean default true
);

create persistent entity OdTest.Order (
  OrderNumber: string(50) unique error 'OrderNumber must be unique' required error 'OrderNumber is required',
  OrderDate: datetime,
  TotalAmount: decimal,
  Status: string(50)
);

create association OdTest.Order_Customer
from OdTest.Order to OdTest.Customer
type reference
owner default;

-- ############################################################################
-- MARK: - Show OData Clients
-- ############################################################################

/**
 * Level 1.1: Show all OData clients
 * Lists all consumed OData services across all modules.
 * Output columns: Module, QualifiedName, Version, OData, MetadataUrl, Validated
 */
list odata clients;
/

/**
 * Level 1.2: Show OData clients in a specific module
 * Lists only consumed OData services in the specified module.
 */
list odata clients in OdTest;
/

-- ############################################################################
-- MARK: - Describe OData Client
-- ############################################################################

-- Level 2.1: Describe an OData client
-- Shows the full MDL definition of a consumed OData service, including
-- version, OData version, metadata URL, timeout, and proxy settings.
-- The output is a re-executable CREATE ODATA CLIENT statement.
-- Usage: DESCRIBE ODATA CLIENT OdTest.ExternalAPI;

-- ############################################################################
-- MARK: - Show OData Services
-- ############################################################################

/**
 * Level 3.1: Show all OData services
 * Lists all published OData services across all modules.
 * Output columns: Module, QualifiedName, Path, Version, OData, EntitySets, AuthTypes
 */
list odata services;
/

/**
 * Level 3.2: Show OData services in a specific module
 * Lists only published OData services in the specified module.
 */
list odata services in OdTest;
/

-- ############################################################################
-- MARK: - Describe OData Service
-- ############################################################################

-- Level 4.1: Describe an OData service
-- Shows the full MDL definition of a published OData service, including:
-- - Service properties (path, version, namespace, authentication)
-- - Published entity types with EXPOSE member lists
-- - Entity set configurations (read/insert/update/delete modes, paging)
-- The output is a re-executable CREATE ODATA SERVICE statement.
-- Usage: DESCRIBE ODATA SERVICE OdTest.CustomerAPI;

-- ############################################################################
-- MARK: - Show External Entities
-- ############################################################################

/**
 * Level 5.1: Show all external entities
 * Lists all entities backed by OData remote sources across all modules.
 * Output columns: Module, QualifiedName, Service, EntitySet, RemoteName, Countable
 */
list external entities;
/

/**
 * Level 5.2: Show external entities in a specific module
 * Lists only external entities in the specified module.
 */
list external entities in OdTest;
/

-- ############################################################################
-- MARK: - Describe External Entity
-- ############################################################################

-- Level 6.1: Describe an external entity
-- Shows the full MDL definition of an external entity, including:
-- - The source OData client reference
-- - Entity set and remote name mappings
-- - Capabilities (countable, creatable, deletable, updatable)
-- - Attributes with their types
-- The output is a re-executable CREATE EXTERNAL ENTITY statement.
-- Usage: DESCRIBE EXTERNAL ENTITY OdTest.RemoteCustomer;

-- ############################################################################
-- MARK: - Catalog Queries
-- ############################################################################

/**
 * Level 7.1: Query OData clients from the catalog
 * The CATALOG.ODATA_CLIENTS table contains all consumed OData services.
 */
select * from catalog.ODATA_CLIENTS;
/

/**
 * Level 7.2: Query OData services from the catalog
 * The CATALOG.ODATA_SERVICES table contains all published OData services.
 */
select * from catalog.ODATA_SERVICES;
/

/**
 * Level 7.3: Find external entities via catalog
 * External entities have IsExternal = 1 in the CATALOG.ENTITIES table.
 */
select * from catalog.entities where IsExternal = 1;
/

-- ############################################################################
-- MARK: - Write Support (CREATE / ALTER / DROP)
-- ############################################################################

/**
 * Level 8.1: Create a consumed OData service (client)
 * Registers an external OData API that the application can consume.
 *
 * Uses the public TripPin reference service (services.odata.org) so that
 * the $metadata is actually reachable — Mendix validates entity/action
 * references against the cached schema, so a service with an unreachable
 * MetadataUrl makes downstream `call external action` activities and
 * external entities trigger CE6611/CE6612/CE7251 noise (and sometimes
 * crash Studio Pro outright — see mxcli#590).
 *
 * ServiceUrl is required (CE5111) and must reference a constant (CE6825),
 * so we declare the constant inline before the service.
 */
create constant OdTest.TripPinAPIServiceUrl
  type string
  default 'https://services.odata.org/TripPinRESTierService/';

create odata client OdTest.TripPinAPI (
  version: '1.0',
  ODataVersion: OData4,
  MetadataUrl: 'https://services.odata.org/TripPinRESTierService/$metadata',
  timeout: 300,
  ServiceUrl: @OdTest.TripPinAPIServiceUrl,
  ProxyType: DefaultProxy,
  folder: 'Integration/TripPin'
);
/

/**
 * Level 8.2: Create a published OData service
 * Exposes domain model entities as OData endpoints with authentication and CRUD modes.
 */
create odata service OdTest.CustomerAPI (
  path: 'odata/customers/',
  version: '1.0.0',
  ODataVersion: OData4,
  namespace: 'OdTest.Customers',
  ServiceName: 'Customer Service',
  Summary: 'API for managing customers',
  PublishAssociations: Yes,
  folder: 'Integration/APIs'
)
authentication basic, session
{
  publish entity OdTest.Customer as 'Customers' (
    ReadMode: source,
    InsertMode: source,
    UpdateMode: source,
    DeleteMode: not_supported,
    UsePaging: Yes,
    PageSize: 100
  )
  expose (
    Email as 'customerId' (KEY, Filterable, Sortable),
    Name (Filterable, Sortable),
    Phone,
    IsActive,
    -- Navigate from a Customer to its Orders. The bare name resolves
    -- against the module's associations (OdTest.Order_Customer here);
    -- the alias becomes the OData navigation property name.
    Order_Customer as 'Orders'
  );

  publish entity OdTest.Order as 'Orders' (
    ReadMode: source,
    InsertMode: not_supported,
    UpdateMode: not_supported,
    DeleteMode: not_supported
  )
  expose (
    OrderNumber as 'orderId' (KEY, Filterable, Sortable),
    OrderDate (Sortable),
    TotalAmount (Sortable),
    Status (Filterable),
    -- Reverse navigation: from an Order to its owning Customer.
    Order_Customer as 'Customer'
  );
};
/

/**
 * Level 8.2a: Create a consumed OData service with full HTTP configuration
 * Includes authentication, custom service URL, microflow references, and headers.
 * Prerequisites: microflows and constants must exist before referencing them.
 */
-- ConfigurationMicroflow signature is fixed by Mendix: returns
-- System.ConsumedODataConfiguration (CE6808). It can take parameters if
-- needed but the return type is what's enforced.
create microflow OdTest.ConfigureRequest() returns System.ConsumedODataConfiguration
begin
    $Config = create System.ConsumedODataConfiguration;
    return $Config;
end;

-- ErrorHandlingMicroflow signature is fixed by Mendix: exactly one
-- parameter of type System.HttpResponse, returning string (CE6815).
create microflow OdTest.HandleError(httpResponse: System.HttpResponse) returns string
begin
  return 'Error handling';
end;

-- HeadersMicroflow signature is fixed by Mendix: returns a list of
-- System.HttpHeader (CE6816).
create microflow OdTest.SetHeaders() returns list of System.HttpHeader
begin
    $Headers = create list of System.HttpHeader;
    return $Headers;
end;

create constant OdTest.ProxyHostConst
type string
default 'proxy.example.com';

create constant OdTest.ProxyPortConst
type string
default '8080';

create constant OdTest.FullConfigAPIServiceUrl
type string
default 'https://api.example.com/odata/v4';

create constant OdTest.HeadersConfigAPIServiceUrl
type string
default 'https://api.example.com/odata/v4';
/

-- ConfigurationMicroflow is mutually exclusive with constant-based ServiceUrl
-- and proxy settings (CE0783, CE1135). FullConfigAPI demonstrates the
-- constant-based path; for the microflow path see how it's exposed in the
-- Mendix System module's ConsumedODataConfiguration entity.
create odata client OdTest.FullConfigAPI (
  version: '3.0',
  ODataVersion: OData4,
  MetadataUrl: 'https://api.example.com/odata/v4/$metadata',
  timeout: 300,
  ServiceUrl: @OdTest.FullConfigAPIServiceUrl,
  UseAuthentication: Yes,
  -- HttpUsername/HttpPassword/ClientCertificate are Mendix expression fields:
  -- the stored value must be a Mendix expression string, so a string literal
  -- needs single quotes inside the MDL string (use doubled '' to escape).
  HttpUsername: '''admin''',
  HttpPassword: '''secret''',
  ClientCertificate: '''my-cert''',
  ErrorHandlingMicroflow: microflow OdTest.HandleError
  -- ProxyHost and ProxyPort are constant references but the BSON shape Mendix
  -- expects isn't well-defined yet; passing them as `@OdTest.X` BSON-stores
  -- `@OdTest.X` and Mendix can't resolve the literal name, passing them
  -- unprefixed makes Mendix parse the value as an expression (CE0117). For
  -- now, omit; configure proxy via project Constants if needed.
)
-- Header values are Mendix expression fields too; wrap literal values in
-- single quotes (escaped as doubled '') so the BSON stores a valid
-- string-literal expression rather than a bare identifier.
headers (
  'X-Api-Key': '''abc123''',
  'Accept': '''application/json'''
);
/

/**
 * Level 8.2b: Consumed OData service with a Headers microflow.
 *
 * Mendix 11.9's "Configuration source" dropdown has three options:
 *   - Constants only            (the default — set ServiceUrl as a constant)
 *   - Configuration microflow
 *   - Headers microflow
 *
 * Both microflow options share a single BSON field — `ConfigurationMicroflow` —
 * and Studio Pro picks the dropdown label from the microflow's return type:
 *   - returns System.ConsumedODataConfiguration -> "Configuration microflow"
 *   - returns list of System.HttpHeader         -> "Headers microflow"
 *
 * The MDL keyword `HeadersMicroflow` is a self-documenting alias for
 * `ConfigurationMicroflow`; both write the same BSON. The microflow
 * paths are mutually exclusive with constants-based ServiceUrl / proxy
 * fields (Mendix raises CE0783/CE1135), so each variant lives in its
 * own service. HeadersConfigAPI's SetHeaders returns a list of
 * System.HttpHeader; the call site provides the service URL itself via
 * the constant ServiceUrl above.
 */
create odata client OdTest.HeadersConfigAPI (
  version: '3.0',
  ODataVersion: OData4,
  MetadataUrl: 'https://api.example.com/odata/v4/$metadata',
  timeout: 300,
  ServiceUrl: @OdTest.HeadersConfigAPIServiceUrl,
  HeadersMicroflow: microflow OdTest.SetHeaders,
  ErrorHandlingMicroflow: microflow OdTest.HandleError
);
/

/**
 * Level 8.2c: Consumed OData service with a Configuration microflow.
 *
 * The microflow returns a System.ConsumedODataConfiguration that
 * carries the runtime service URL plus any headers/auth. When this path
 * is used the static ServiceUrl / proxy constants on the service itself
 * are omitted — Mendix raises CE0783/CE1135 if both are set.
 *
 * NOTE: Mendix 11.11 reworked the consumed-OData "Configuration source"
 * model: a ConfigurationMicroflow service with no static ServiceUrl now
 * fails project check with CE5111 ("Service URL not specified") on both
 * engines — mxcli does not yet emit the 11.11 shape. Version-gated to
 * <= 11.10 so the doctype mx-check parity gate (which builds an 11.11
 * project) stays green; tracked as a separate 11.11 OData-config issue.
 */
-- @version: ..11.10
create odata client OdTest.MicroflowConfigAPI (
  version: '3.0',
  ODataVersion: OData4,
  MetadataUrl: 'https://api.example.com/odata/v4/$metadata',
  timeout: 300,
  ConfigurationMicroflow: microflow OdTest.ConfigureRequest,
  ErrorHandlingMicroflow: microflow OdTest.HandleError
);
/
-- @version: any

/**
 * Level 8.3: Create or modify (idempotent) - updates if it already exists
 */
create or modify odata client OdTest.TripPinAPI (
  version: '2.0',
  ODataVersion: OData4,
  MetadataUrl: 'https://services.odata.org/TripPinRESTierService/$metadata',
  timeout: 600
);
/

/**
 * Level 8.4: Alter an OData client property
 */
alter odata client OdTest.TripPinAPI
  set timeout = 600;
/

/**
 * Level 8.5: Alter an OData service property
 */
alter odata service OdTest.CustomerAPI
  set version = '2.0.0';
/

-- ############################################################################
-- LEVEL 8.6: CREATE EXTERNAL ENTITY (singular form)
-- ############################################################################
--
-- The singular `create external entity` examples below use the TripPin
-- reference service so Mendix can validate the entity/attribute mapping
-- against cached $metadata (CE6611/CE6612 only fire when the consumed
-- service has no metadata). Levels 8.6a-c live here for syntax coverage;
-- for bulk import see Level 10.2.
--
-- TripPinClient.TripPinApiClient is created in Level 10.1, so the singular
-- examples below depend on it — keep Level 10 first if reordering.
-- ############################################################################

-- ############################################################################
-- LEVEL 8.7: GRANT/REVOKE ACCESS ON ODATA SERVICE
-- ############################################################################

/**
 * Level 8.7a: Grant access on a published OData service
 */
create module role OdTest.Admin;
create module role OdTest.user;
grant access on odata service OdTest.CustomerAPI to OdTest.Admin, OdTest.user;
/

/**
 * Level 8.7b: Revoke access on a published OData service
 */
revoke access on odata service OdTest.CustomerAPI from OdTest.user;
/

-- ############################################################################
-- LEVEL 9: EXTERNAL ACTION CALLS IN MICROFLOWS
-- ############################################################################

-- Level 9.1: Call an external action — see Level 10.4.1 below.
--
-- All consumed-service examples in this file use TripPin (a real OData
-- reference service with reachable $metadata), so Studio Pro's project
-- checker can resolve `call external action` Name fields against the
-- cached schema. Using a service with an unreachable MetadataUrl makes
-- the cache empty and crashes the checker (see mxcli#590).

/**
 * Level 9.2: Show external actions discovered from microflow usage
 */
show external actions;
/
show external actions in OdTest;
/

-- ############################################################################
-- LEVEL 10: CREATE EXTERNAL ENTITIES (bulk from contract)
-- ############################################################################
--
-- Bulk-creates external entities from the TripPin RW OData service.
-- Validates mendixlabs/mxcli#143: key, attribute OData mapping, and
-- capability annotations are all written correctly to BSON.
--
-- Requires network access to services.odata.org (public, no auth).
-- CREATE ODATA CLIENT fetches and caches $metadata automatically.
--
-- ############################################################################

/**
 * Level 10.0: Set up the TripPin module, role, and constant.
 */
create module TripPinClient;
/

create module role TripPinClient."user"
  description 'Role for TripPin API access';
/

create constant TripPinClient."TripPinServiceUrl"
  type string
  default 'https://services.odata.org/TripPinRESTierService/';
/

/**
 * Level 10.1: Register the TripPin RW service.
 * CREATE ODATA CLIENT fetches and caches $metadata from MetadataUrl.
 * ServiceUrl must reference a constant (CE6825).
 */
create odata client TripPinClient."TripPinApiClient" (
  ODataVersion: OData4,
  MetadataUrl: 'https://services.odata.org/TripPinRESTierService/$metadata',
  timeout: 300,
  ServiceUrl: @TripPinClient.TripPinServiceUrl,
  UseAuthentication: No
);
/

/**
 * Level 10.2: Bulk import all entity types from the TripPin contract.
 * Creates one external entity per OData entity type. Top-level entity
 * sets (Airlines, Airports, People) use the set name; derived/contained
 * types (Flight, PlanItem, Trip, etc.) use the type name.
 */
create external entities from TripPinClient."TripPinApiClient";
/

/**
 * Level 10.3: Import only specific entity types by name.
 */
create or modify external entities from TripPinClient."TripPinApiClient"
  entities (Airline, Airport);
/

/**
 * Level 10.4: Import all entities into a different module.
 */
create or modify external entities from TripPinClient."TripPinApiClient"
  into TripPinClient;
/

/**
 * Level 10.4.1: Demonstrate `call external action` against an unbound TripPin
 * Action. ResetDataSource is the only unbound Action in TripPin's $metadata;
 * GetNearestAirport and friends are Functions, which Mendix's `call external
 * action` activity does not accept (CE7251). The microflow lives in OdTest
 * to keep `show external actions in OdTest` (Level 9.2) returning a row, but
 * references the TripPin client.
 */
create microflow OdTest.ACT_CallExternalAction() returns boolean
begin
    -- ResetDataSource is an unbound OData Action in TripPin's $metadata.
    -- `call external action` only supports OData Actions, not Functions
    -- (CE7251) — GetNearestAirport is a Function so it can't be called here.
    -- Error handling type 'on error continue' is rejected for external
    -- action calls (CE6035), so we just call without it.
    call external action TripPinClient."TripPinApiClient".ResetDataSource();
    return true;
end;
/

-- ############################################################################
-- LEVEL 8.8: DROP (cleanup)
-- ############################################################################
-- Cleanup statements below are commented out by default; flip them on if
-- you want to re-run this script idempotently. Halt execution here so the
-- example file produces a project ready for Studio Pro inspection.
exit;

-- Level 8.8a: drop objects that reference OData clients first.
-- drop microflow OdTest.ACT_CallExternalAction;
--
-- Level 8.8b: drop OData clients.
-- drop odata client OdTest.FullConfigAPI;
-- drop odata client OdTest.HeadersConfigAPI;
-- drop odata client OdTest.MicroflowConfigAPI;
-- drop odata client OdTest.TripPinAPI;
--
-- Level 8.8c: drop the TripPin client (cascades to its external entities).
-- drop odata client TripPinClient."TripPinApiClient";
--
-- Level 8.8d: drop the published OData service.
-- drop odata service OdTest.CustomerAPI;

-- ############################################################################
-- END OF ODATA EXAMPLES
-- ############################################################################
