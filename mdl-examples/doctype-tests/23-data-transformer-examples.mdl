-- @version: 11.9+
-- ============================================================================
-- Data Transformer Examples
-- ============================================================================
--
-- Demonstrates creating, describing, listing, and modifying data transformers.
--
-- This script leaves two transformers in the project (DtTest.FlattenNested and
-- DtTest.WeatherTransform) so the result can be inspected in Studio Pro. The
-- cleanup DROP statements at the end are commented out and preceded by `exit;`;
-- flip them on (and remove the exit) if you want to re-run idempotently.
--
-- Prerequisites:
--   - Mendix 11.9+ (Data Transformers require >= 11.9)
--
-- ============================================================================

create module DtTest;

-- ############################################################################
-- PART 1: SIMPLE SINGLE-LINE JSLT TRANSFORMER
-- ############################################################################

-- Flatten a nested JSON object using a single-line JSLT expression.
create data transformer DtTest.FlattenNested
source json '{"wrapper": {"value": 42, "label": "hello"}}'
{
  jslt '{"value": .wrapper.value, "label": .wrapper.label}';
};

-- ############################################################################
-- PART 2: MULTI-LINE JSLT TRANSFORMER WITH $$ QUOTING
-- ############################################################################

-- Extract key fields from a weather API response using a multi-line JSLT step.
create data transformer DtTest.WeatherTransform
source json '{"latitude": 51.9, "longitude": 4.5, "timezone": "Europe/Amsterdam", "current": {"time": "2024-01-15T14:00", "temperature_2m": 12.8, "wind_speed_10m": 18.3, "weather_code": 3}}'
{
  jslt $$
{
  "lat":        .latitude,
  "lon":        .longitude,
  "timezone":   .timezone,
  "temp":       .current.temperature_2m,
  "wind_speed": .current.wind_speed_10m,
  "code":       .current.weather_code
}
  $$;
};

-- ############################################################################
-- PART 3: LIST AND DESCRIBE
-- ############################################################################

-- List all data transformers in the project
list data transformers;

-- List data transformers in a specific module
list data transformers in DtTest;

-- Describe a transformer (outputs a re-executable CREATE statement)
describe data transformer DtTest.WeatherTransform;

-- ############################################################################
-- PART 4: CREATE OR MODIFY (idempotent upsert)
-- ############################################################################
--
-- CREATE OR MODIFY updates an existing transformer in-place, preserving its
-- UUID. Re-run-safe: if the transformer doesn't exist it is created; if it
-- does exist its steps are replaced without changing the document identity.
--
-- Here we modify the WeatherTransform created in PART 2 to project a smaller,
-- renamed shape — the transformer stays in the project for Studio Pro to inspect.

create or modify data transformer DtTest.WeatherTransform
source json '{"latitude": 51.9, "longitude": 4.5, "timezone": "Europe/Amsterdam", "current": {"temperature_2m": 12.8}}'
{
  jslt $$
{
  "lat":      .latitude,
  "lon":      .longitude,
  "timezone": .timezone,
  "temp":     .current.temperature_2m
}
  $$;
};

describe data transformer DtTest.WeatherTransform;

-- ############################################################################
-- PART 5: CLEANUP (disabled)
-- ############################################################################
--
-- Halt here so the script leaves DtTest.FlattenNested and DtTest.WeatherTransform
-- in the project for Studio Pro inspection. To re-run this script idempotently,
-- remove the `exit;` and uncomment the DROP statements below.

exit;

-- drop data transformer DtTest.FlattenNested;
-- drop data transformer DtTest.WeatherTransform;
-- drop module DtTest;
