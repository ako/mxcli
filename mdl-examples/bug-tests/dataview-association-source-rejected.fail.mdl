-- MDL-WIDGET08 negative test: a plain DataView cannot use an association data
-- source (Studio Pro: "data view 'X' cannot have a data source of type
-- association"). `check` must reject this; use a list widget instead.
-- See assoc-datasource-modelsdk.mdl for the valid (listview) form.
create entity MyFirstModule.Employee ( Name: String );
create entity MyFirstModule.Expense ( Description: String );
create association MyFirstModule.Expense_Employee
  from MyFirstModule.Expense to MyFirstModule.Employee;

create or replace page MyFirstModule.BadAssocDataView
( Title: 'Bad', Layout: Atlas_Core.Atlas_Default, Params: { $Employee: MyFirstModule.Employee } )
{
  dataview dvEmp (datasource: $Employee) {
    dataview dvBad (datasource: $currentObject/MyFirstModule.Expense_Employee) {
      dynamictext t (content: 'x')
    }
  }
}
