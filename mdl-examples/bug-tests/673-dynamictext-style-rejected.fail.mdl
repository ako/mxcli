-- Bug #673: an inline `style` on a dynamictext must be rejected by mxcli check
--
-- NEGATIVE TEST (.fail.mdl) — this script is EXPECTED to fail `mxcli check`.
-- `make check-mdl` inverts the exit code for .fail.mdl files: an unexpected
-- pass would be reported as a regression of the MDL-WIDGET03 rule.
--
-- Symptom: applying `style: '...'` directly to a DYNAMICTEXT widget produced
-- BSON that crashes MxBuild with a NullReferenceException — it failed at build,
-- not at check.
--
-- Fix: mxcli now rejects an inline style on a dynamictext (MDL-WIDGET03) and
-- points to the workaround: wrap the widget in a container and style the
-- container instead.
--
-- Expected: `mxcli check` exits non-zero with MDL-WIDGET03 on dtBad.

create page BugTest.DynamicTextStylePage
(
  title: 'Dynamic Text Style',
  layout: Atlas_Core.Atlas_Default,
  url: 'bug633_dynamictext_style'
)
{
  dynamictext dtBad (content: 'Hello', style: 'color: red;')
}
